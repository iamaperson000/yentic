# PostgreSQL database used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yentic"

# NextAuth / Google OAuth
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
AUTH_SECRET="replace-with-a-long-random-secret"

# Pusher Channels (required for the /chat demo)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Liveblocks (required for the /collab demo)
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY="pk_dev_your-liveblocks-public-key"

# Liveblocks server-side auth (required for the IDE collaborative editor)
LIVEBLOCKS_SECRET_KEY="sk_dev_your-liveblocks-secret-key"
